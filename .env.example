# Copy this to .env and fill in values
# On Railway, set these as environment variables in the dashboard

# Comma-separated list of allowed frontend origins
# Local dev: leave empty (allows all) or set to http://localhost:5173
# Production: set to your Vercel URL e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Enables GET /backtest, the model-evaluation tool.
# Local only — leave this UNSET on Railway. It retrains the model once per race,
# so an open endpoint in production is an easy way for anyone to stall the backend.
BACKTEST_ENABLED=true
